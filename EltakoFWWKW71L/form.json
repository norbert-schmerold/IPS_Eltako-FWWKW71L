{
    "elements": [
        {
            "type": "Label",
            "caption": "Eltako FWWKW71L – 2-Kanal-PWM-Dimmer (WW/KW). Ersatz-Treiber, der die Rückmeldungen des Aktors auswertet. Hängt als Child am EnOcean-Gateway."
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "DeviceID",
                    "caption": "Geräte-ID",
                    "minimum": 0,
                    "maximum": 127
                },
                {
                    "type": "Button",
                    "caption": "Wähle verfügbare Geräte-ID",
                    "onClick": "EFW_PickFreeDeviceID($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Sende-Adresse: {{SENDER}}"
        },
        {
            "type": "Select",
            "name": "SendFormat",
            "caption": "Sende-Format",
            "options": [
                { "caption": "Prozent (DataByte2 = 0–100, WW=ID / KW=ID+1)", "value": "percent" },
                { "caption": "Hochauflösend (10-Bit, Kanal in DataByte1, eine ID)", "value": "hires" }
            ]
        },
        {
            "type": "Label",
            "name": "DetectedFormatLabel",
            "caption": "Empfangenes Format (automatisch erkannt): {{DETECTED}}"
        },
        {
            "type": "CheckBox",
            "name": "EmulateStatus",
            "caption": "Status emulieren (Werte sofort aus gesendeten Befehlen setzen)"
        },
        {
            "type": "ValidationTextBox",
            "name": "MeldeID",
            "caption": "Melde-ID (hex). Prozent: WW-ID (KW = +1). Hochauflösend: eine ID (z. B. FFF02404)."
        },
        {
            "type": "Button",
            "caption": "Rückmeldeadresse automatisch erkennen",
            "onClick": "EFW_DetectMelde($id);"
        },
        {
            "type": "Label",
            "name": "MeldeStatus",
            "caption": "Empfang wird automatisch dekodiert (beide Formate). Geräte-ID muss gesetzt sein – der Aktor wird kurz angestoßen.   Aktuell: {{MELDE}}"
        },
        {
            "type": "CheckBox",
            "name": "DebugPromiscuous",
            "caption": "Debug: ALLE eingehenden Telegramme ausgeben (Feldnamen prüfen)"
        }
    ],
    "actions": [
        {
            "type": "Label",
            "caption": "Gateway-BaseID: {{BASEID}}"
        },
        {
            "type": "Label",
            "caption": "Drücken Sie Einlernen, nachdem Sie das Gerät in den Lernmodus versetzt haben (ein Teach-In für WW und KW)."
        },
        {
            "type": "Button",
            "caption": "Einlernen",
            "onClick": "EFW_TeachIn($id);"
        },
        {
            "type": "Label",
            "caption": "Steuerung:"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "Beide 100 %",
                    "onClick": "EFW_AllOn($id);"
                },
                {
                    "type": "Button",
                    "caption": "Beide 50 %",
                    "onClick": "EFW_SetBoth($id, 50, 50);"
                },
                {
                    "type": "Button",
                    "caption": "Aus",
                    "onClick": "EFW_SwitchOff($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Suchen: sammelt 30 s lang alle eingehenden 4BS-Sender-IDs. Schalten Sie den Aktor dabei mehrfach – die Melde-ID erscheint mit hohem Zähler. Dann unten übernehmen."
        },
        {
            "type": "Button",
            "caption": "Suchen (30 s)",
            "onClick": "EFW_StartDiscovery($id);"
        },
        {
            "type": "List",
            "name": "DiscoveryList",
            "caption": "Gefundene 4BS-IDs",
            "rowCount": 6,
            "add": false,
            "delete": false,
            "columns": [
                {
                    "caption": "Sender-ID (hex)",
                    "name": "SenderIDHex",
                    "width": "180px"
                },
                {
                    "caption": "DB2",
                    "name": "DB2",
                    "width": "80px"
                },
                {
                    "caption": "Anzahl",
                    "name": "Count",
                    "width": "80px"
                }
            ],
            "values": []
        },
        {
            "type": "Button",
            "caption": "Ausgewählte → Melde-ID",
            "onClick": "EFW_AdoptDiscovered($id, $DiscoveryList['SenderIDHex']);"
        }
    ],
    "status": []
}
