{
    "elements": [
        {
            "type": "Label",
            "caption": "Eltako FWWKW71L – 2-Kanal-PWM-Dimmer (WW/KW). Ersatz-Treiber, der die Rückmeldungen des Aktors auswertet."
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "DeviceID",
                    "caption": "Geräte-ID",
                    "minimum": 0,
                    "maximum": 127
                },
                {
                    "type": "Button",
                    "caption": "Freie Geräte-ID wählen",
                    "onClick": "EFW_PickFreeDeviceID($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Sende-Adresse: {{SENDER}}"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "ValidationTextBox",
                    "name": "MeldeID",
                    "caption": "Melde-ID (hex)"
                },
                {
                    "type": "Button",
                    "caption": "Automatisch erkennen",
                    "onClick": "EFW_DetectMelde($id);"
                }
            ]
        },
        {
            "type": "Label",
            "name": "InfoLabel",
            "caption": "{{INFO}}"
        },
        {
            "type": "ExpansionPanel",
            "caption": "Erweitert",
            "items": [
                {
                    "type": "CheckBox",
                    "name": "EmulateStatus",
                    "caption": "Status emulieren (Werte sofort aus gesendeten Befehlen setzen)"
                },
                {
                    "type": "CheckBox",
                    "name": "DebugPromiscuous",
                    "caption": "Debug: ALLE eingehenden Telegramme ausgeben"
                }
            ]
        }
    ],
    "actions": [
        {
            "type": "Label",
            "caption": "Gateway-BaseID: {{BASEID}}"
        },
        {
            "type": "Label",
            "caption": "Einrichtung neues Gerät: Drehschalter (Mitte) des Aktors auf Position 8 stellen, dann Einlernen drücken. Danach Melde-ID automatisch erkennen."
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "Einlernen",
                    "onClick": "EFW_TeachIn($id);"
                },
                {
                    "type": "Button",
                    "caption": "100 %",
                    "onClick": "EFW_AllOn($id);"
                },
                {
                    "type": "Button",
                    "caption": "50 %",
                    "onClick": "EFW_SetBoth($id, 50, 50);"
                },
                {
                    "type": "Button",
                    "caption": "Aus",
                    "onClick": "EFW_SwitchOff($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Melde-ID manuell finden: Suchen starten und den Aktor schalten – die Melde-ID erscheint mit hohem Zähler, dann übernehmen."
        },
        {
            "type": "Button",
            "caption": "Suchen (30 s)",
            "onClick": "EFW_StartDiscovery($id);"
        },
        {
            "type": "List",
            "name": "DiscoveryList",
            "caption": "Gefundene 4BS-IDs",
            "rowCount": 6,
            "add": false,
            "delete": false,
            "columns": [
                {
                    "caption": "Sender-ID (hex)",
                    "name": "SenderIDHex",
                    "width": "180px"
                },
                {
                    "caption": "DB2",
                    "name": "DB2",
                    "width": "80px"
                },
                {
                    "caption": "Anzahl",
                    "name": "Count",
                    "width": "80px"
                }
            ],
            "values": []
        },
        {
            "type": "Button",
            "caption": "Ausgewählte → Melde-ID",
            "onClick": "EFW_AdoptDiscovered($id, $DiscoveryList['SenderIDHex']);"
        }
    ],
    "status": []
}
