{
    "elements": [
        {
            "type": "Label",
            "caption": "Eltako FWWKW71L – 2-Kanal-PWM-Dimmer (WW/KW). Ersatz-Treiber, der die Rückmeldungen des Aktors auswertet. Hängt als Child am EnOcean-Gateway."
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "NumberSpinner",
                    "name": "DeviceID",
                    "caption": "Geräte-ID",
                    "minimum": 0,
                    "maximum": 127
                },
                {
                    "type": "Button",
                    "caption": "Wähle verfügbare Geräte-ID",
                    "onClick": "EFW_PickFreeDeviceID($id);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Sende-Adresse WW: {{SENDER_WW}}   |   KW (Geräte-ID + 1): {{SENDER_KW}}"
        },
        {
            "type": "CheckBox",
            "name": "EmulateStatus",
            "caption": "Status emulieren (Werte sofort aus gesendeten Befehlen setzen)"
        },
        {
            "type": "ValidationTextBox",
            "name": "MeldeID",
            "caption": "Melde-ID (hex, z. B. FFF01A81)"
        },
        {
            "type": "Label",
            "caption": "Melde-ID für bidirektionale Antwort. WW = Melde-ID, KW = Melde-ID + 1.   Aktuell: WW {{MELDE_WW}} / KW {{MELDE_KW}}"
        },
        {
            "type": "CheckBox",
            "name": "DebugPromiscuous",
            "caption": "Debug: ALLE eingehenden Telegramme ausgeben (Feldnamen prüfen)"
        }
    ],
    "actions": [
        {
            "type": "Label",
            "caption": "Gateway-BaseID: {{BASEID}}"
        },
        {
            "type": "Label",
            "caption": "Drücken Sie Einlernen, nachdem Sie das Gerät in den Lernmodus versetzt haben (ein Teach-In für WW und KW)."
        },
        {
            "type": "Button",
            "caption": "Einlernen",
            "onClick": "EFW_TeachIn($id);"
        },
        {
            "type": "RowLayout",
            "items": [
                {
                    "type": "Button",
                    "caption": "Test EIN (100/100)",
                    "onClick": "EFW_SetBoth($id, 100, 100);"
                },
                {
                    "type": "Button",
                    "caption": "Test AUS",
                    "onClick": "EFW_SwitchOff($id);"
                },
                {
                    "type": "Button",
                    "caption": "Test 50 %",
                    "onClick": "EFW_SetBoth($id, 50, 50);"
                }
            ]
        },
        {
            "type": "Label",
            "caption": "Suchen: sammelt 30 s lang alle eingehenden 4BS-Sender-IDs. Schalten Sie den Aktor dabei mehrfach – die Melde-ID erscheint mit hohem Zähler. Dann unten übernehmen."
        },
        {
            "type": "Button",
            "caption": "Suchen (30 s)",
            "onClick": "EFW_StartDiscovery($id);"
        },
        {
            "type": "List",
            "name": "DiscoveryList",
            "caption": "Gefundene 4BS-IDs",
            "rowCount": 6,
            "add": false,
            "delete": false,
            "columns": [
                {
                    "caption": "Sender-ID (hex)",
                    "name": "SenderIDHex",
                    "width": "180px"
                },
                {
                    "caption": "DB2",
                    "name": "DB2",
                    "width": "80px"
                },
                {
                    "caption": "Anzahl",
                    "name": "Count",
                    "width": "80px"
                }
            ],
            "values": []
        },
        {
            "type": "Button",
            "caption": "Ausgewählte → Melde-ID",
            "onClick": "EFW_AdoptDiscovered($id, $DiscoveryList['SenderIDHex']);"
        }
    ],
    "status": []
}
